<Window x:Class="NeoStrike.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NEOSTRIKE" Width="1260" Height="820"
        WindowStartupLocation="CenterScreen"
        Background="#000000"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Space Grotesk, Segoe UI, sans-serif"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Storyboard x:Key="OrbFloat1" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="-40" To="40" Duration="0:0:14"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="-50" To="50" Duration="0:0:18"/>
        </Storyboard>
        <Storyboard x:Key="OrbFloat2" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="50" To="-50" Duration="0:0:18"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="40" To="-40" Duration="0:0:15"/>
        </Storyboard>
    </Window.Resources>

    <Border Background="#050510" CornerRadius="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== ROW 0: TITLE BAR ===== -->
            <Grid Grid.Row="0" Background="#080818" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="NEOSTRIKE"
                           FontFamily="Orbitron, Consolas" FontSize="12" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="18,0,0,0">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#6366F1" Offset="0"/>
                            <GradientStop Color="#EC4899" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Width="34" Height="28" Background="Transparent" BorderThickness="0"
                            Foreground="#666" Cursor="Hand" Click="Minimize_Click"
                            Content="&#xE949;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    <Button Width="34" Height="28" Background="Transparent" BorderThickness="0"
                            Foreground="#666" Cursor="Hand" Click="Maximize_Click"
                            Content="&#xE739;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    <Button Width="34" Height="28" Background="Transparent" BorderThickness="0"
                            Foreground="#666" Cursor="Hand" Click="Close_Click"
                            Content="&#xE106;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                </StackPanel>
            </Grid>

            <!-- ===== ROW 1: CONTENT AREA ===== -->
            <Grid Grid.Row="1" ClipToBounds="True">
                <!-- Background orbs -->
                <Canvas IsHitTestVisible="False" ClipToBounds="True">
                    <Ellipse Width="700" Height="700" Opacity="0.18" Canvas.Left="450" Canvas.Top="-100">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#6366F1" Offset="0"/>
                                <GradientStop Color="#6366F1" Offset="0.2"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.RenderTransform><TranslateTransform/></Ellipse.RenderTransform>
                    </Ellipse>
                    <Ellipse Width="600" Height="600" Opacity="0.15" Canvas.Left="-100" Canvas.Top="250">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#EC4899" Offset="0"/>
                                <GradientStop Color="#EC4899" Offset="0.2"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.RenderTransform><TranslateTransform/></Ellipse.RenderTransform>
                    </Ellipse>
                    <Ellipse Width="500" Height="500" Opacity="0.12" Canvas.Left="350" Canvas.Top="200">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#06B6D4" Offset="0"/>
                                <GradientStop Color="#06B6D4" Offset="0.2"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.RenderTransform><TranslateTransform/></Ellipse.RenderTransform>
                    </Ellipse>
                </Canvas>

                <!-- Main content grid -->
                <Grid Margin="20,12,20,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="0.9*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- MARQUEE -->
                    <Border Grid.ColumnSpan="2" Grid.Row="0" Margin="0,0,0,12" Height="42"
                            CornerRadius="21" ClipToBounds="True"
                            Background="#08FFFFFF" BorderBrush="#0CFFFFFF" BorderThickness="1">
                        <Canvas ClipToBounds="True">
                            <StackPanel x:Name="MarqueeTrack" Orientation="Horizontal" Canvas.Top="10">
                                <TextBlock Text="  DESIGN  " FontSize="14" FontWeight="SemiBold" Foreground="#6366F1" Opacity="0.6" Margin="0,0,4,0"/>
                                <TextBlock Text="&#x25CF;" FontSize="7" Foreground="#6366F1" Opacity="0.3" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="  DEVELOP  " FontSize="14" FontWeight="SemiBold" Foreground="#EC4899" Opacity="0.6" Margin="0,0,4,0"/>
                                <TextBlock Text="&#x25CF;" FontSize="7" Foreground="#EC4899" Opacity="0.3" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="  CREATE  " FontSize="14" FontWeight="SemiBold" Foreground="#06B6D4" Opacity="0.6" Margin="0,0,4,0"/>
                                <TextBlock Text="&#x25CF;" FontSize="7" Foreground="#06B6D4" Opacity="0.3" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="  INNOVATE  " FontSize="14" FontWeight="SemiBold" Foreground="#F59E0B" Opacity="0.6" Margin="0,0,4,0"/>
                                <TextBlock Text="&#x25CF;" FontSize="7" Foreground="#F59E0B" Opacity="0.3" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="  IMAGINE  " FontSize="14" FontWeight="SemiBold" Foreground="#00FF41" Opacity="0.6" Margin="0,0,4,0"/>
                                <TextBlock Text="&#x25CF;" FontSize="7" Foreground="#00FF41" Opacity="0.3" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="  BUILD  " FontSize="14" FontWeight="SemiBold" Foreground="#FF00FF" Opacity="0.6" Margin="0,0,4,0"/>
                                <TextBlock Text="&#x25CF;" FontSize="7" Foreground="#FF00FF" Opacity="0.3" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="  NEOSTRIKE  " FontFamily="Orbitron, Consolas" FontSize="14" FontWeight="SemiBold" Foreground="#FFF" Opacity="0.3" Margin="0,0,30,0"/>
                            </StackPanel>
                        </Canvas>
                    </Border>

                    <!-- LEFT COLUMN -->
                    <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,6,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Target -->
                        <Border Grid.Row="0" Margin="0,0,0,10" Padding="22,18" CornerRadius="20"
                                Background="#0CFFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Target" FontSize="11" FontWeight="500" Foreground="#888" Margin="0,0,0,10"/>
                                <TextBox x:Name="TxtTarget" FontSize="13" FontFamily="Space Grotesk, Segoe UI"
                                         Background="#06FFFFFF" Foreground="#FFFFFF" BorderBrush="#10FFFFFF"
                                         BorderThickness="1" Padding="14,10" CaretBrush="#6366F1"
                                         Text="https://example.com" VerticalContentAlignment="Center"/>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <CheckBox x:Name="ChkProxy" Content="SOCKS5 Proxy" FontSize="11"
                                                  Foreground="#666" Margin="0,0,10,0"/>
                                        <CheckBox x:Name="ChkMultiTarget" Content="Multi-Target" FontSize="11"
                                                  Foreground="#666"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Save" FontSize="10" Foreground="#555"
                                            Background="Transparent" BorderThickness="0"
                                            Click="SavePreset_Click" Cursor="Hand" Padding="8,2"/>
                                </Grid>
                                <TextBox x:Name="TxtProxy" Width="180" FontSize="11"
                                         Background="#06FFFFFF" Foreground="#888" BorderBrush="#10FFFFFF"
                                         BorderThickness="1" Padding="10,6" Visibility="Collapsed"
                                         Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- HTTP Path -->
                        <Border Grid.Row="1" Margin="0,0,0,10" Padding="22,14" CornerRadius="20"
                                Background="#0CFFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="HTTP Path" FontSize="11" FontWeight="500" Foreground="#888" Margin="0,0,0,6"/>
                                <TextBox x:Name="TxtPath" FontSize="12" FontFamily="Space Grotesk, Consolas"
                                         Background="#06FFFFFF" Foreground="#06B6D4" BorderBrush="#10FFFFFF"
                                         BorderThickness="1" Padding="14,8" CaretBrush="#06B6D4"
                                         Text="/" VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Attack Mode -->
                        <Border Grid.Row="2" Margin="0,0,0,10" Padding="22,18" CornerRadius="20"
                                Background="#0CFFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Attack Mode" FontSize="11" FontWeight="500" Foreground="#888" Margin="0,0,0,10"/>
                                <WrapPanel Margin="0,0,0,12">
                                    <ToggleButton x:Name="BtnGet" Content="GET" IsChecked="True" Margin="0,0,6,6"
                                                  Click="Mode_Click" Tag="GET" FontSize="11" Padding="14,8"
                                                  Background="#12FFFFFF" Foreground="#6366F1" BorderBrush="#18FFFFFF"
                                                  BorderThickness="1" Cursor="Hand"/>
                                    <ToggleButton x:Name="BtnPost" Content="POST" Margin="0,0,6,6"
                                                  Click="Mode_Click" Tag="POST" FontSize="11" Padding="14,8"
                                                  Background="#12FFFFFF" Foreground="#666" BorderBrush="#18FFFFFF"
                                                  BorderThickness="1" Cursor="Hand"/>
                                    <ToggleButton x:Name="BtnHead" Content="HEAD" Margin="0,0,6,6"
                                                  Click="Mode_Click" Tag="HEAD" FontSize="11" Padding="14,8"
                                                  Background="#12FFFFFF" Foreground="#666" BorderBrush="#18FFFFFF"
                                                  BorderThickness="1" Cursor="Hand"/>
                                    <ToggleButton x:Name="BtnPut" Content="PUT" Margin="0,0,6,6"
                                                  Click="Mode_Click" Tag="PUT" FontSize="11" Padding="14,8"
                                                  Background="#12FFFFFF" Foreground="#666" BorderBrush="#18FFFFFF"
                                                  BorderThickness="1" Cursor="Hand"/>
                                    <ToggleButton x:Name="BtnDelete" Content="DEL" Margin="0,0,6,6"
                                                  Click="Mode_Click" Tag="DELETE" FontSize="11" Padding="14,8"
                                                  Background="#12FFFFFF" Foreground="#666" BorderBrush="#18FFFFFF"
                                                  BorderThickness="1" Cursor="Hand"/>
                                    <ToggleButton x:Name="BtnTcp" Content="TCP" Margin="0,0,6,6"
                                                  Click="Mode_Click" Tag="TCP" FontSize="11" Padding="14,8"
                                                  Background="#12FFFFFF" Foreground="#666" BorderBrush="#18FFFFFF"
                                                  BorderThickness="1" Cursor="Hand"/>
                                    <ToggleButton x:Name="BtnUdp" Content="UDP" Margin="0,0,6,6"
                                                  Click="Mode_Click" Tag="UDP" FontSize="11" Padding="14,8"
                                                  Background="#12FFFFFF" Foreground="#666" BorderBrush="#18FFFFFF"
                                                  BorderThickness="1" Cursor="Hand"/>
                                    <ToggleButton x:Name="BtnSlow" Content="SLOW" Margin="0,0,6,6"
                                                  Click="Mode_Click" Tag="SLOWLORIS" FontSize="11" Padding="14,8"
                                                  Background="#12FFFFFF" Foreground="#666" BorderBrush="#18FFFFFF"
                                                  BorderThickness="1" Cursor="Hand"/>
                                    <ToggleButton x:Name="BtnRudy" Content="RUDY" Margin="0,0,6,6"
                                                  Click="Mode_Click" Tag="RUDY" FontSize="11" Padding="14,8"
                                                  Background="#12FFFFFF" Foreground="#666" BorderBrush="#18FFFFFF"
                                                  BorderThickness="1" Cursor="Hand"/>
                                    <ToggleButton x:Name="BtnWs" Content="WS" Margin="0,0,6,6"
                                                  Click="Mode_Click" Tag="WEBSOCKET" FontSize="11" Padding="14,8"
                                                  Background="#12FFFFFF" Foreground="#666" BorderBrush="#18FFFFFF"
                                                  BorderThickness="1" Cursor="Hand"/>
                                    <ToggleButton x:Name="BtnSyn" Content="SYN" Margin="0,0,6,6"
                                                  Click="Mode_Click" Tag="SYN" FontSize="11" Padding="14,8"
                                                  Background="#12FFFFFF" Foreground="#666" BorderBrush="#18FFFFFF"
                                                  BorderThickness="1" Cursor="Hand"/>
                                </WrapPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Threads" FontSize="10" Foreground="#666" Margin="0,0,0,4"/>
                                            <TextBlock x:Name="LblThreads" Grid.Column="1" Text="100" FontSize="10"
                                                       Foreground="#6366F1" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        </Grid>
                                        <Slider x:Name="SliderThreads" Minimum="1" Maximum="500" Value="100"
                                                Foreground="#6366F1" TickFrequency="10" IsSnapToTickEnabled="True"
                                                ValueChanged="SliderThreads_ValueChanged"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                        <TextBlock Text="Duration" FontSize="10" Foreground="#666" Margin="0,0,0,4"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox x:Name="TxtDuration" Width="50" FontSize="11"
                                                     Background="#06FFFFFF" Foreground="#FFF" BorderBrush="#10FFFFFF"
                                                     BorderThickness="1" Padding="6,5" Text="60"/>
                                            <TextBlock Text="s" FontSize="10" Foreground="#666" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="14,0,0,0">
                                        <TextBlock Text="Rate/s" FontSize="10" Foreground="#666" Margin="0,0,0,4"/>
                                        <TextBox x:Name="TxtRate" Width="60" FontSize="11"
                                                 Background="#06FFFFFF" Foreground="#FFF" BorderBrush="#10FFFFFF"
                                                 BorderThickness="1" Padding="6,5" Text="100"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Controls -->
                        <Border Grid.Row="3" Margin="0,0,0,10" Padding="22,18" CornerRadius="20"
                                Background="#0CFFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Controls" FontSize="11" FontWeight="500" Foreground="#888" Margin="0,0,0,10"/>
                                <WrapPanel>
                                    <Button x:Name="BtnStart" Content="Launch" FontSize="12" FontWeight="600"
                                            Padding="28,12" Cursor="Hand" Margin="0,0,10,0"
                                            Foreground="#FFFFFF" BorderThickness="0"
                                            Click="BtnStart_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" CornerRadius="20" Padding="{TemplateBinding Padding}">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#6366F1" Offset="0"/>
                                                            <GradientStop Color="#8B5CF6" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button x:Name="BtnStop" Content="Stop" FontSize="12" FontWeight="600"
                                            Padding="28,12" Cursor="Hand"
                                            Foreground="#888" BorderThickness="1" BorderBrush="#18FFFFFF"
                                            Background="#12FFFFFF"
                                            Click="BtnStop_Click" IsEnabled="False">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}"
                                                        BorderThickness="1" BorderBrush="{TemplateBinding BorderBrush}"
                                                        CornerRadius="20" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="BorderBrush" Value="#FF0033"/>
                                                        <Setter Property="Foreground" Value="#FF0033"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button x:Name="BtnExport" Content="Export" FontSize="11" FontWeight="500"
                                            Padding="16,12" Cursor="Hand" Margin="10,0,0,0"
                                            Foreground="#06B6D4" BorderThickness="1" BorderBrush="#18FFFFFF"
                                            Background="#12FFFFFF"
                                            Click="Export_Click"/>
                                </WrapPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <CheckBox x:Name="ChkPulse" Content="Pulse Mode" FontSize="11" Foreground="#666" Margin="0,0,16,0"/>
                                    <TextBlock Text="Burst" FontSize="10" Foreground="#555" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox x:Name="TxtPulseBurst" Width="40" FontSize="11"
                                             Background="#06FFFFFF" Foreground="#CCC" BorderBrush="#10FFFFFF"
                                             BorderThickness="1" Padding="6,5" Text="4" VerticalContentAlignment="Center"/>
                                    <TextBlock Text="s" FontSize="10" Foreground="#555" VerticalAlignment="Center" Margin="6,0,14,0"/>
                                    <TextBlock Text="Pause" FontSize="10" Foreground="#555" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox x:Name="TxtPulsePause" Width="40" FontSize="11"
                                             Background="#06FFFFFF" Foreground="#CCC" BorderBrush="#10FFFFFF"
                                             BorderThickness="1" Padding="6,5" Text="2" VerticalContentAlignment="Center"/>
                                    <TextBlock Text="s" FontSize="10" Foreground="#555" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- KPI -->
                        <Border Grid.Row="4" Margin="0,0,0,10" Padding="18,16" CornerRadius="20"
                                Background="#0CFFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock x:Name="KpiPps" Text="0" FontFamily="Orbitron, Consolas" FontSize="24" FontWeight="Bold"
                                               Foreground="#6366F1" HorizontalAlignment="Center"/>
                                    <TextBlock Text="pkt/s" FontSize="9" Foreground="#666" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock x:Name="KpiBps" Text="0" FontFamily="Orbitron, Consolas" FontSize="24" FontWeight="Bold"
                                               Foreground="#EC4899" HorizontalAlignment="Center"/>
                                    <TextBlock Text="MB/s" FontSize="9" Foreground="#666" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock x:Name="KpiConn" Text="0" FontFamily="Orbitron, Consolas" FontSize="24" FontWeight="Bold"
                                               Foreground="#06B6D4" HorizontalAlignment="Center"/>
                                    <TextBlock Text="conn" FontSize="9" Foreground="#666" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                    <TextBlock x:Name="KpiErrors" Text="0" FontFamily="Orbitron, Consolas" FontSize="24" FontWeight="Bold"
                                               Foreground="#FF0033" HorizontalAlignment="Center"/>
                                    <TextBlock Text="errors" FontSize="9" Foreground="#666" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Progress -->
                        <Border Grid.Row="5" Margin="0,0,0,0" Padding="22,16" CornerRadius="20"
                                Background="#0CFFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Height="5" Background="#0AFFFFFF" CornerRadius="3" ClipToBounds="True"
                                        VerticalAlignment="Center">
                                    <Border x:Name="ProgressFill" Width="0" Height="5" CornerRadius="3"
                                            HorizontalAlignment="Left">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#6366F1" Offset="0"/>
                                                <GradientStop Color="#EC4899" Offset="0.5"/>
                                                <GradientStop Color="#06B6D4" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Border>
                                <TextBlock x:Name="LblTimer" Grid.Column="1" Text="00:00"
                                           FontFamily="Orbitron, Consolas" FontSize="13" FontWeight="Bold"
                                           Foreground="#666" VerticalAlignment="Center" Margin="14,0,0,0"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- RIGHT COLUMN -->
                    <Grid Grid.Row="1" Grid.Column="1" Margin="6,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Active Mode -->
                        <Border Grid.Row="0" Margin="0,0,0,10" Padding="22,18" CornerRadius="20"
                                Background="#0CFFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Active Mode" FontSize="11" FontWeight="500" Foreground="#888" Margin="0,0,0,6"/>
                                    <TextBlock x:Name="LblActiveMode" Text="GET FLOOD"
                                               FontFamily="Orbitron, Consolas" FontSize="22" FontWeight="Bold">
                                        <TextBlock.Foreground>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#6366F1" Offset="0"/>
                                                <GradientStop Color="#EC4899" Offset="1"/>
                                            </LinearGradientBrush>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                </StackPanel>
                                <Border Grid.Column="1" Width="50" Height="50" CornerRadius="25" VerticalAlignment="Center"
                                        Opacity="0.5">
                                    <Border.Background>
                                        <RadialGradientBrush>
                                            <GradientStop x:Name="ModeOrbColor1" Color="#6366F1" Offset="0"/>
                                            <GradientStop Color="#00000000" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Console -->
                        <Border Grid.Row="1" Margin="0,0,0,10" Padding="16,12" CornerRadius="20"
                                Background="#0CFFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Console" FontSize="11" FontWeight="500" Foreground="#888"/>
                                    <Button Grid.Column="1" Content="Clear" FontSize="10" Foreground="#555"
                                            Background="Transparent" BorderThickness="0"
                                            Click="ClearLog_Click" Cursor="Hand"/>
                                </Grid>
                                <Border Grid.Row="1" Background="#06FFFFFF" CornerRadius="12" Padding="12,8"
                                        BorderBrush="#08FFFFFF" BorderThickness="1">
                                    <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                                        <TextBlock x:Name="LogConsole" FontFamily="Consolas, Courier New"
                                                   FontSize="11" Foreground="#555" TextWrapping="Wrap">
                                            <TextBlock.Text>[SYS] NEOSTRIKE v2.1 initialized...&#x0a;</TextBlock.Text>
                                        </TextBlock>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Chart -->
                        <Border Grid.Row="2" Margin="0,0,0,0" Padding="16,12" CornerRadius="20"
                                Background="#0CFFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1"
                                Height="165">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Bandwidth" FontSize="11" FontWeight="500" Foreground="#888"/>
                                    <TextBlock x:Name="LblBwPeak" Grid.Column="1" Text="Peak: 0 MB/s"
                                               FontSize="9" Foreground="#555"/>
                                </Grid>
                                <Border Grid.Row="1" Background="#06FFFFFF" CornerRadius="12" ClipToBounds="True"
                                        BorderBrush="#08FFFFFF" BorderThickness="1">
                                    <Canvas x:Name="ChartCanvas" ClipToBounds="True"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Footer -->
                <Border Height="28" Margin="20,0,20,8" VerticalAlignment="Bottom"
                        CornerRadius="14" Background="#06FFFFFF" BorderBrush="#08FFFFFF" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Authorized stress testing only" FontSize="9" Foreground="#FFF" Opacity="0.2"/>
                        <TextBlock Text="  &#x00B7;  " FontSize="6" Foreground="#6366F1" Opacity="0.3" VerticalAlignment="Center"/>
                        <TextBlock Text="All traffic is logged" FontSize="9" Foreground="#FFF" Opacity="0.2"/>
                        <TextBlock Text="  &#x00B7;  " FontSize="6" Foreground="#EC4899" Opacity="0.3" VerticalAlignment="Center"/>
                        <TextBlock Text="NEOSTRIKE v2.1" FontFamily="Orbitron, Consolas" FontSize="9" Foreground="#FFF" Opacity="0.25"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
